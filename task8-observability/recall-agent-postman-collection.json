    {
      "name": "01 - Valid Make Model Year",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has response field\", function(){",
              "    var json = pm.response.json();",
              "    pm.expect(json.response).to.be.a('string').and.not.empty;",
              "});",
              "pm.test(\"Response has latency_ms\", function(){",
              "    pm.expect(pm.response.json().latency_ms).to.be.a('number');",
              "});",
              "pm.test(\"Model is correct\", function(){",
              "    pm.expect(pm.response.json().model).to.eql(\"claude-sonnet-4-6\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
